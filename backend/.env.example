OPENAI_API_KEY=replace_me
GROQ_API_KEY=replace_me
ANTHROPIC_API_KEY=replace_me

GOOGLE_OAUTH_CLIENT_ID=replace_me
GOOGLE_OAUTH_CLIENT_SECRET=replace_me


ALLOWED_ORIGINS=http://localhost:3000
FRONTEND_URL=http://localhost:3000
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/callback

# Managed GA4 → BigQuery export (service account JSON + target GCP project)
GA4_EXPORT_GCP_PROJECT_ID=your-gcp-project-id
GA4_BQ_DATASET_LOCATION=US
GA4_LINK_SERVICE_ACCOUNT_EMAIL=connector@your-gcp-project-id.iam.gserviceaccount.com
# Path to the same service account key JSON (or set GOOGLE_APPLICATION_CREDENTIALS instead)
GA4_LINK_SERVICE_ACCOUNT_FILE=

OAUTHLIB_INSECURE_TRANSPORT=1

